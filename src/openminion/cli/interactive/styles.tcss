FocusScreen {
    layout: vertical;
}

#focus-root {
    layout: vertical;
    height: 100%;
}

FocusHeader {
    height: 1;
    dock: top;
    padding: 0 1;
    background: $surface;
    color: $text;
}

#focus-header-row {
    height: 1;
    width: 100%;
}

#focus-header-agent {
    width: 16;
    text-style: bold;
}

#focus-header-dir {
    width: 1fr;
}

#focus-header-runtime {
    width: 30;
    color: $text-muted;
}

#focus-header-session {
    width: 24;
}

#focus-header-clock {
    width: 8;
    content-align: right middle;
}

#focus-header-status {
    width: 6;
    content-align: right middle;
}

FocusStatusLine {
    dock: bottom;
    height: 1;
    padding: 0 1;
    background: $panel;
    color: $text-muted;
}

#focus-screen-main {
    layout: vertical;
    height: 1fr;
}

#focus-debug-pane {
    height: auto;
    max-height: 10;
    border: round $panel;
    padding: 0 1;
}

#focus-debug-pane.--hidden {
    display: none;
}

/* Rich-renderer widgets. The internal `.focus-*` selectors remain stable
 * compatibility identifiers for existing themes and tests. */

.focus-inline-prompt,
.focus-approval {
    border: round $panel;
    margin: 1 0;
    padding: 0 1;
    height: auto;
}

.focus-inline-prompt-title,
.focus-approval-title {
    text-style: bold;
}

#focus-tools-overlay-title,
#focus-session-overlay-title {
    dock: top;
    padding: 1;
    text-style: bold;
}

/* FIU-02: bordered input chrome. The frame wraps the shared
 * `ChatInputBar` so the input reads as the primary affordance
 * (Claude Code / Codex style). Border color comes from the shared
 * theme catalog via the THM textual adapter — `surface_divider`
 * adapts to LIGHT vs DARK so the frame stays legible in either.
 * Dashboard's `ChatTab` does not mount this container, so its
 * input remains borderless. */
#focus-input-frame {
    border: round $openminion-surface-divider;
    padding: 0 1;
    height: auto;
    margin: 0 0 0 0;
}
